{
	"name": "schedule-server",
	"type": "module",
	"version": "1.0.0",
	"description": "API server for the calendar-schedule-server of Takshashila SCS(in TypeScript).",
	"private": true,
	"license": "MIT",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/src/index.js",
		"migrate": "pnpm exec drizzle-kit migrate",
		"generate": "pnpm exec drizzle-kit generate",
		"format:write": "pnpx @biomejs/biome format --write ./src",
		"lint": "pnpx @biomejs/biome lint ./src",
		"lint:fix": "pnpx @biomejs/biome lint --write ./src"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^8.5.0",
		"@hono/node-server": "^1.19.14",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.4.0",
		"@hono/zod-validator": "^0.8.0",
		"date-fns": "^4.1.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"is-deflate": "^1.0.0",
		"is-gzip": "^2.0.0",
		"pako": "^2.1.0",
		"pg": "^8.20.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/is-deflate": "^1.0.0",
		"@types/is-gzip": "^2.0.2",
		"@types/node": "^20.11.17",
		"@types/pako": "^2.0.4",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.7.1",
		"typed-htmx": "^0.3.1",
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": "24.13.0"
	},
	"packageManager": "pnpm@11.1.1"
}
